{
  "name": "repobridge",
  "version": "1.0.0",
  "description": "Cross-repo intelligence CLI — research, plan, and implement features spanning multiple repositories",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "repobridge": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "cross-repo",
    "monorepo",
    "ai",
    "claude",
    "openai",
    "architecture",
    "code-analysis",
    "developer-tools"
  ],
  "author": "Alameer Ashraf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlameerAshraf/RepoBridge.git"
  },
  "homepage": "https://github.com/AlameerAshraf/RepoBridge#readme",
  "bugs": {
    "url": "https://github.com/AlameerAshraf/RepoBridge/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.5"
  }
}
