{
  "name": "repobridge",
  "version": "1.0.0",
  "description": "Cross-repo intelligence CLI — research, plan, and implement features spanning multiple repositories",
  "main": "dist/index.js",
  "bin": {
    "repobridge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "npm run build || true"
  },
  "type": "module",
  "keywords": ["cli", "monorepo", "ai", "claude", "cross-repo"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inkjs/ui": "^2.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ora": "^8.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "strip-ansi": "^7.1.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.5"
  }
}
